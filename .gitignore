# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Local configuration file (sdk path, etc)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
*.iws
*.ipr
out/

# VS Code
.vscode/

# Mac
.DS_Store

# NDK
obj/
*.so

# Model files (large binary files)
app/src/main/assets/models/*.gguf
app/src/main/assets/models/*.bin

# Keystore files
*.jks
*.keystore

# Local gradle launcher copy (not needed in source control)
lib/
